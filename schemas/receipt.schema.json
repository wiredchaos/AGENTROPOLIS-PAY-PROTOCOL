{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentropolis.example/schemas/receipt.schema.json",
  "title": "AGENTROPOLIS Pay Receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "intent_id", "mandate_id", "outcome", "provider", "recorded_at"],
  "properties": {
    "id": {"type": "string", "minLength": 1},
    "intent_id": {"type": "string", "minLength": 1},
    "mandate_id": {"type": "string", "minLength": 1},
    "approval_id": {"type": "string"},
    "outcome": {"enum": ["denied", "expired", "revoked", "succeeded", "failed", "reversed", "refunded"]},
    "provider": {"type": "string", "minLength": 1},
    "provider_reference": {"type": "string"},
    "amount": {"type": "string", "pattern": "^[0-9]+(\\.[0-9]+)?$"},
    "asset": {"type": "string"},
    "recorded_at": {"type": "string", "format": "date-time"},
    "evidence_digest": {"type": "string", "minLength": 16},
    "previous_receipt_digest": {"type": "string"},
    "metadata": {"type": "object"}
  }
}
